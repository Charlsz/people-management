generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Persona {
  tipo_documento   String   @db.VarChar(30)
  nro_documento    String   @id @db.VarChar(10)
  primer_nombre    String   @db.VarChar(30)
  segundo_nombre   String?  @db.VarChar(30)
  apellidos        String   @db.VarChar(60)
  fecha_nacimiento DateTime @db.Date
  genero           String   @db.VarChar(20)
  email            String   @db.VarChar(255)
  celular          String   @db.VarChar(10)
  foto_url         String?  @db.Text
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@map("personas")
}

model Log {
  id      Int      @id @default(autoincrement())
  tipo    String   @db.VarChar(20)
  doc     String   @db.VarChar(10)
  fecha   DateTime @default(now())
  detalle String   @db.Text

  @@map("logs")
}
